<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.algolist.backend.user.UserDao">

	<!-- 컬럼의 user_id와 UserDao의 userId가 일치하지 않으므로 이름 맞춰주기 -->
	<resultMap type="UserDto" id="UserDtoMap" autoMapping="true">
		<id column="user_id" property="userId"/>
	</resultMap>
	
	<!-- 모든 유저 반환 -->
	<select id="selectAllUsers" resultMap="UserDtoMap">
		SELECT user_id, username, role
		FROM users
	</select>
	
	<!-- 특정 username을 가진 유저만 반환 -->
	<select id="selectUser" resultMap="UserDtoMap">
		SELECT user_id, username, password, role
		FROM users
		WHERE username = #{username}
	</select>
	
	<!-- username, password 기반으로 새 유저 INSERT(user_id, role은 자동 생성) -->
	<insert id="insertUser">
		INSERT INTO users(username, password)
		VALUES(#{username}, #{password})
	</insert>
	
	<!-- username 기반으로 유저 UPDATE -->
	<update id="updateUser">
		UPDATE users
		SET password = #{password}
		WHERE username = #{username}
	</update>
	
	<!-- username 기반으로 유저 DELETE -->
	<delete id="deleteUser">
		DELETE FROM users
		WHERE username = #{username}
	</delete>
	
</mapper>
