<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.algolist.backend.user.UserDao">

	<!-- 컬럼의 user_id와 UserDao의 userId가 일치하지 않으므로 이름 맞춰주기 -->
	<resultMap type="UserDto" id="UserDtoMap" autoMapping="true">
		<id column="user_id" property="userId"/>
		<result column="account_status" property="accountStatus"/>
		<result column="created_at" property="createdAt"/>
		<result column="deleted_at" property="deletedAt"/>
	</resultMap>

	<resultMap type="UserDetailDto" id="UserDetailDtoMap" autoMapping="true">
		<result column="profile_image_url" property="profileImageUrl"/>
	</resultMap>
	
	<!-- 모든 유저 반환 -->
	<select id="selectAllUsers" resultMap="UserDtoMap">
		SELECT user_id, username, nickname, role, created_at, deleted_at, account_status
		FROM users
	</select>
	
	<!-- 특정 username을 가진 유저만 반환(비밀번호 미포함) -->
	<select id="selectUser" resultMap="UserDetailDtoMap">
		SELECT username, nickname, profile_image_url, bio, role
		FROM users
		WHERE username = #{username}
	</select>
	
	<!-- 특정 username을 가진 유저만 반환(비밀번호 포함) -->
	<select id="selectUserForAuth" resultMap="UserDtoMap">
		SELECT user_id, username, password, role, account_status
		FROM users
		WHERE username = #{username}
	</select>
	
	<!-- username, password 기반으로 새 유저 INSERT(user_id, role은 자동 생성) -->
	<insert id="insertUser">
		INSERT INTO users(username, password)
		VALUES(#{username}, #{password})
	</insert>
	
	<!-- username 기반으로 유저 UPDATE -->
	<update id="updateUser">
		UPDATE users
		<set>
			<if test="nickname != null">
				nickname = #{nickname},
			</if>
			<if test="password != null">
				password = #{password},
			</if>
			<if test="bio != null">
				bio = #{bio},
			</if>
			<if test="profileImageUrl != null">
				profile_image_url = #{profileImageUrl},
			</if>
		</set>
		WHERE username = #{username}
	</update>
	
	<!-- username 기반으로 유저 Soft Delete -->
	<update id="deleteUser">
		UPDATE users
		SET account_status = 'DELETED',
			deleted_at = CURRENT_TIMESTAMP
		WHERE username = #{username}
		  AND account_status != 'DELETED'
	</update>
	
</mapper>
