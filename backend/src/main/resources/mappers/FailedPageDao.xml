<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.algolist.backend.problem.batch.common.FailedPageDao">

    <!-- 실패한 페이지 기록 (status 는 기본값 PENDING, created_at 은 기본값 NOW) -->
    <insert id="insertFailedPage">
        INSERT INTO failed_pages (source, page_offset, page_size, reason)
        VALUES (#{source}, #{pageOffset}, #{pageSize}, #{reason})
    </insert>

</mapper>
