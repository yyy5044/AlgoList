<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.algolist.backend.problem.ProblemDao">

	<!-- 문제 생성: problems에 1행 INSERT -->
	<insert id="insertProblem" parameterType="ProblemDto"
	        useGeneratedKeys="true" keyProperty="id" keyColumn="problem_id">
		INSERT INTO problems (title, number, difficulty, site, link, user_id)
		VALUES (#{title}, #{number}, #{difficulty}, #{site}, #{link}, #{userId})
		<!-- grade, solve_count, last_solved_date는 넣지 않아 DB DEFAULT(solve_count=0 등)가 적용된다 -->
	</insert>

	<!-- 카테고리 N행 INSERT: foreach로 (problem_id, category_name) 묶음을 콤마로 이어붙인다 -->
	<insert id="insertCategories">
		INSERT INTO problem_categories (problem_id, category_name)
		VALUES
		<foreach collection="categories" item="cat" separator=",">
			(#{problemId}, #{cat})
		</foreach>
	</insert>

</mapper>
